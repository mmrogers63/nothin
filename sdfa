docker run --rm \
  --platform linux/amd64 \
  -v $(pwd)/rootfs:/target \
  -v $(pwd)/out:/out \
  --entrypoint sh \
  chainguard/openscap:latest \
  -c "oscap xccdf eval \
      --skip-cpe-check \
      --profile xccdf_org.ssgproject.content_profile_standard \
      --results /out/results.xml \
      --report /out/report.html \
      /usr/share/xml/scap/ssg/content/ssg-debian12-ds.xml"
